---
// ThemeToggle: switches between Academic (book) and DS9 (rocket) mode
---
<button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
  <span class="theme-toggle__academic" title="Academic mode">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
  </span>
  <span class="theme-toggle__ds9" title="DS9 mode">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>
  </span>
</button>

<style>
  .theme-toggle {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    background: none;
    border: 1px solid var(--color-border);
    padding: 0.3rem 0.5rem;
    cursor: pointer;
    color: var(--color-text);
    line-height: 1;
  }

  .theme-toggle:hover {
    border-color: var(--color-accent);
  }

  .theme-toggle__academic,
  .theme-toggle__ds9 {
    display: flex;
    align-items: center;
    padding: 0.15rem;
  }

  [data-theme="academic"] .theme-toggle__academic {
    opacity: 1;
    background: var(--color-accent);
    color: var(--color-bg);
    border-radius: 2px;
  }

  [data-theme="academic"] .theme-toggle__ds9 {
    opacity: 0.3;
  }

  [data-theme="ds9"] .theme-toggle__ds9 {
    opacity: 1;
    background: var(--color-accent);
    color: var(--color-bg);
    border-radius: 2px;
  }

  [data-theme="ds9"] .theme-toggle__academic {
    opacity: 0.3;
  }
</style>

<script>
  const toggle = document.getElementById('theme-toggle');
  const root = document.documentElement;

  function setTheme(theme: string) {
    root.setAttribute('data-theme', theme);
    localStorage.setItem('theme', theme);
  }

  // Init from localStorage or default to academic
  const saved = localStorage.getItem('theme') || 'academic';
  setTheme(saved);

  toggle?.addEventListener('click', () => {
    const current = root.getAttribute('data-theme');
    setTheme(current === 'academic' ? 'ds9' : 'academic');
  });
</script>
