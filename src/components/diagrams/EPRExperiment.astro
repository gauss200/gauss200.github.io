---
// EPR experiment spacetime diagram.
// Vertical axis: time. Horizontal axis: spatial separation.
// Two entangled spin-1/2 particles in a singlet state diverge from a common origin.
// A measurement on one branch at angle theta collapses the other branch's spin.
// Shows the conditional probability distribution P(phi) = sin^2((phi - theta)/2)
// for the second measurement outcome as a function of measurement angle phi.
---
<div class="diagram-container">
  <h3>EPR Experiment — Entangled Spin Singlet</h3>
  <p class="diagram-desc">
    Two spin-½ particles are created in a singlet state |&psi;⟩ = (|&uarr;&darr;⟩ &minus; |&darr;&uarr;⟩)/&radic;2
    and fly apart. A measurement on particle A along axis &theta; yields spin-up.
    The probability of measuring spin-up on particle B along axis &phi; is
    P(&uarr;) = sin²((&phi; &minus; &theta;)/2). Adjust &theta; and &phi; to explore the correlations.
  </p>
  <div class="diagram-controls">
    <label>
      Measurement A (&theta;):
      <input type="range" id="epr-theta" min="0" max="360" step="1" value="0" />
      <span id="epr-theta-val">0°</span>
    </label>
    <label>
      Measurement B (&phi;):
      <input type="range" id="epr-phi" min="0" max="360" step="1" value="180" />
      <span id="epr-phi-val">180°</span>
    </label>
    <label>
      Measurement time:
      <input type="range" id="epr-mtime" min="0.2" max="0.8" step="0.05" value="0.5" />
    </label>
  </div>
  <canvas id="epr-experiment" width="800" height="600"></canvas>
</div>

<style>
  .diagram-container {
    margin: 2rem 0;
    padding: 1.5rem;
    background: var(--color-card-bg);
    border-radius: var(--border-radius);
    box-shadow: 0 2px 8px var(--color-card-shadow);
  }

  .diagram-desc {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .diagram-controls {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .diagram-controls label {
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  canvas {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--border-radius);
  }
</style>

<script>
  const canvas = document.getElementById('epr-experiment') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const thetaSlider = document.getElementById('epr-theta') as HTMLInputElement;
  const thetaValEl = document.getElementById('epr-theta-val')!;
  const phiSlider = document.getElementById('epr-phi') as HTMLInputElement;
  const phiValEl = document.getElementById('epr-phi-val')!;
  const mtimeSlider = document.getElementById('epr-mtime') as HTMLInputElement;

  let time = 0;

  thetaSlider.addEventListener('input', () => { thetaValEl.textContent = thetaSlider.value + '°'; });
  phiSlider.addEventListener('input', () => { phiValEl.textContent = phiSlider.value + '°'; });

  function draw() {
    const W = canvas.width;
    const H = canvas.height;
    const thetaDeg = parseFloat(thetaSlider.value);
    const phiDeg = parseFloat(phiSlider.value);
    const mTimeFrac = parseFloat(mtimeSlider.value);
    const theta = thetaDeg * Math.PI / 180;
    const phi = phiDeg * Math.PI / 180;

    const isDark = document.documentElement.getAttribute('data-theme') === 'ds9';

    ctx.clearRect(0, 0, W, H);
    ctx.fillStyle = isDark ? '#05050f' : '#fafafa';
    ctx.fillRect(0, 0, W, H);

    const colorA = isDark ? '#e8a640' : '#e63946';
    const colorB = isDark ? '#64b5f6' : '#457b9d';
    const colorSinglet = isDark ? '#cc99ff' : '#7c3aed';
    const colorCorr = isDark ? '#33cccc' : '#2a9d8f';
    const textColor = isDark ? '#c8cad8' : '#1a1a1a';
    const mutedColor = isDark ? '#7a7e9a' : '#888';
    const axisColor = isDark ? '#1a1a4a' : '#e0e0e0';
    const lightconeColor = isDark ? 'rgba(255,255,255,0.04)' : 'rgba(0,0,0,0.02)';

    // Layout: left 60% is spacetime diagram, right 40% is correlation plot
    const stW = W * 0.55;
    const corrX = W * 0.6;
    const corrW = W * 0.37;

    const margin = { top: 20, bottom: 40 };
    const stH = H - margin.top - margin.bottom;

    // Origin point (singlet creation) — bottom center of spacetime diagram
    const originX = stW / 2;
    const originY = H - margin.bottom;

    // Time runs upward
    const topY = margin.top;

    // === Spacetime diagram (left) ===

    // Time axis
    ctx.strokeStyle = axisColor;
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(originX, originY + 5);
    ctx.lineTo(originX, topY);
    ctx.stroke();

    // Spatial axis
    ctx.beginPath();
    ctx.moveTo(15, originY);
    ctx.lineTo(stW - 5, originY);
    ctx.stroke();

    // Axis labels
    ctx.fillStyle = mutedColor;
    ctx.font = '11px system-ui';
    ctx.fillText('t', originX + 6, topY + 5);
    ctx.fillText('x', stW - 10, originY + 15);
    ctx.fillText('0', originX + 5, originY + 15);

    // Light cone (faint)
    ctx.fillStyle = lightconeColor;
    ctx.beginPath();
    ctx.moveTo(originX, originY);
    ctx.lineTo(originX - stH * 0.45, topY);
    ctx.lineTo(originX + stH * 0.45, topY);
    ctx.closePath();
    ctx.fill();

    // Light cone edges
    ctx.strokeStyle = isDark ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.06)';
    ctx.lineWidth = 1;
    ctx.setLineDash([4, 6]);
    ctx.beginPath();
    ctx.moveTo(originX, originY);
    ctx.lineTo(originX - stH * 0.45, topY);
    ctx.stroke();
    ctx.beginPath();
    ctx.moveTo(originX, originY);
    ctx.lineTo(originX + stH * 0.45, topY);
    ctx.stroke();
    ctx.setLineDash([]);

    // Particle worldlines — diverging at constant velocity
    const velocity = 0.35; // fraction of light speed
    const particleAx = (t: number) => originX - velocity * t * stH * 0.45;
    const particleBx = (t: number) => originX + velocity * t * stH * 0.45;
    const timeToY = (t: number) => originY - t * stH;

    // Measurement events
    const mY = timeToY(mTimeFrac);
    const mAx = particleAx(mTimeFrac);
    const mBx = particleBx(mTimeFrac);

    // Singlet creation event
    ctx.beginPath();
    ctx.fillStyle = colorSinglet;
    ctx.arc(originX, originY, 6, 0, Math.PI * 2);
    ctx.fill();
    ctx.fillStyle = colorSinglet;
    ctx.font = '11px system-ui';
    ctx.textAlign = 'center';
    ctx.fillText('Singlet created', originX, originY + 18);
    ctx.textAlign = 'left';

    // Worldline A (left) — entangled before measurement, collapsed after
    // Before measurement: wavy line (uncertain)
    ctx.strokeStyle = colorA;
    ctx.lineWidth = 2.5;
    ctx.beginPath();
    ctx.moveTo(originX, originY);
    const stepsBeforeM = 40;
    for (let i = 0; i <= stepsBeforeM; i++) {
      const t = (i / stepsBeforeM) * mTimeFrac;
      const x = particleAx(t);
      const y = timeToY(t);
      // Slight wobble to suggest superposition
      const wobble = Math.sin(i * 0.8 + time * 3) * 3 * (1 - i / stepsBeforeM * 0.5);
      ctx.lineTo(x + wobble, y);
    }
    ctx.stroke();

    // After measurement: solid straight line
    ctx.beginPath();
    ctx.moveTo(mAx, mY);
    ctx.lineTo(particleAx(1), topY);
    ctx.stroke();

    // Worldline B (right)
    ctx.strokeStyle = colorB;
    ctx.lineWidth = 2.5;
    ctx.beginPath();
    ctx.moveTo(originX, originY);
    for (let i = 0; i <= stepsBeforeM; i++) {
      const t = (i / stepsBeforeM) * mTimeFrac;
      const x = particleBx(t);
      const y = timeToY(t);
      const wobble = Math.sin(i * 0.8 - time * 3 + 2) * 3 * (1 - i / stepsBeforeM * 0.5);
      ctx.lineTo(x + wobble, y);
    }
    ctx.stroke();

    ctx.beginPath();
    ctx.moveTo(mBx, mY);
    ctx.lineTo(particleBx(1), topY);
    ctx.stroke();

    // Measurement event A — apparatus
    ctx.fillStyle = colorA;
    ctx.beginPath();
    ctx.arc(mAx, mY, 5, 0, Math.PI * 2);
    ctx.fill();

    // Spin arrow for A (result: spin up along theta)
    const arrowLen = 22;
    const aArrowX = mAx - 35;
    const aArrowY = mY;
    ctx.strokeStyle = colorA;
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.moveTo(aArrowX - arrowLen / 2 * Math.cos(theta), aArrowY + arrowLen / 2 * Math.sin(theta));
    ctx.lineTo(aArrowX + arrowLen / 2 * Math.cos(theta), aArrowY - arrowLen / 2 * Math.sin(theta));
    ctx.stroke();
    // Arrowhead
    const tipAx = aArrowX + arrowLen / 2 * Math.cos(theta);
    const tipAy = aArrowY - arrowLen / 2 * Math.sin(theta);
    ctx.beginPath();
    ctx.moveTo(tipAx, tipAy);
    ctx.lineTo(tipAx - 6 * Math.cos(theta - 0.4), tipAy + 6 * Math.sin(theta - 0.4));
    ctx.moveTo(tipAx, tipAy);
    ctx.lineTo(tipAx - 6 * Math.cos(theta + 0.4), tipAy + 6 * Math.sin(theta + 0.4));
    ctx.stroke();

    ctx.fillStyle = colorA;
    ctx.font = '10px system-ui';
    ctx.textAlign = 'center';
    ctx.fillText(`↑ θ=${thetaDeg}°`, mAx - 35, mY - 18);
    ctx.fillText('Meas. A', mAx, mY + 16);
    ctx.textAlign = 'left';

    // Measurement event B — apparatus
    ctx.fillStyle = colorB;
    ctx.beginPath();
    ctx.arc(mBx, mY, 5, 0, Math.PI * 2);
    ctx.fill();

    // Spin arrow for B (measurement axis phi)
    const bArrowX = mBx + 35;
    const bArrowY = mY;
    ctx.strokeStyle = colorB;
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.moveTo(bArrowX - arrowLen / 2 * Math.cos(phi), bArrowY + arrowLen / 2 * Math.sin(phi));
    ctx.lineTo(bArrowX + arrowLen / 2 * Math.cos(phi), bArrowY - arrowLen / 2 * Math.sin(phi));
    ctx.stroke();
    const tipBx = bArrowX + arrowLen / 2 * Math.cos(phi);
    const tipBy = bArrowY - arrowLen / 2 * Math.sin(phi);
    ctx.beginPath();
    ctx.moveTo(tipBx, tipBy);
    ctx.lineTo(tipBx - 6 * Math.cos(phi - 0.4), tipBy + 6 * Math.sin(phi - 0.4));
    ctx.moveTo(tipBx, tipBy);
    ctx.lineTo(tipBx - 6 * Math.cos(phi + 0.4), tipBy + 6 * Math.sin(phi + 0.4));
    ctx.stroke();

    ctx.fillStyle = colorB;
    ctx.font = '10px system-ui';
    ctx.textAlign = 'center';
    ctx.fillText(`φ=${phiDeg}°`, mBx + 35, mY - 18);
    ctx.fillText('Meas. B', mBx, mY + 16);
    ctx.textAlign = 'left';

    // Spacelike separation indicator
    ctx.strokeStyle = mutedColor;
    ctx.lineWidth = 1;
    ctx.setLineDash([3, 3]);
    ctx.beginPath();
    ctx.moveTo(mAx + 8, mY);
    ctx.lineTo(mBx - 8, mY);
    ctx.stroke();
    ctx.setLineDash([]);
    ctx.fillStyle = mutedColor;
    ctx.font = '9px system-ui';
    ctx.textAlign = 'center';
    ctx.fillText('spacelike separated', (mAx + mBx) / 2, mY - 6);
    ctx.textAlign = 'left';

    // Entanglement wiggly line connecting particles (before measurement)
    ctx.strokeStyle = colorSinglet;
    ctx.lineWidth = 1;
    ctx.globalAlpha = 0.3;
    const nWiggles = 12;
    for (let tFrac = 0.05; tFrac < mTimeFrac; tFrac += 0.08) {
      const ax = particleAx(tFrac);
      const bx = particleBx(tFrac);
      const y = timeToY(tFrac);
      ctx.beginPath();
      for (let i = 0; i <= nWiggles; i++) {
        const frac = i / nWiggles;
        const wx = ax + (bx - ax) * frac;
        const wy = y + Math.sin(frac * Math.PI * 4 + time * 2 + tFrac * 10) * 3;
        i === 0 ? ctx.moveTo(wx, wy) : ctx.lineTo(wx, wy);
      }
      ctx.stroke();
    }
    ctx.globalAlpha = 1;

    // === Right panel: Correlation / probability plot ===

    const corrTop = margin.top + 20;
    const corrBottom = H - margin.bottom - 60;
    const corrH = corrBottom - corrTop;
    const corrLeft = corrX;
    const corrRight = corrX + corrW;

    // Title
    ctx.fillStyle = textColor;
    ctx.font = '12px system-ui';
    ctx.textAlign = 'center';
    ctx.fillText('P(↑) for particle B', corrLeft + corrW / 2, corrTop - 8);
    ctx.textAlign = 'left';

    // Axes
    ctx.strokeStyle = axisColor;
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(corrLeft, corrTop);
    ctx.lineTo(corrLeft, corrBottom);
    ctx.lineTo(corrRight, corrBottom);
    ctx.stroke();

    // Y axis labels
    ctx.fillStyle = mutedColor;
    ctx.font = '10px system-ui';
    ctx.fillText('1', corrLeft - 14, corrTop + 4);
    ctx.fillText('0', corrLeft - 14, corrBottom + 4);
    ctx.fillText('½', corrLeft - 14, corrTop + corrH / 2 + 4);

    // Half line
    ctx.strokeStyle = axisColor;
    ctx.lineWidth = 0.5;
    ctx.setLineDash([4, 4]);
    ctx.beginPath();
    ctx.moveTo(corrLeft, corrTop + corrH / 2);
    ctx.lineTo(corrRight, corrTop + corrH / 2);
    ctx.stroke();
    ctx.setLineDash([]);

    // X axis: measurement angle phi of B (0 to 360)
    ctx.fillStyle = mutedColor;
    ctx.font = '10px system-ui';
    ctx.textAlign = 'center';
    ctx.fillText('0°', corrLeft, corrBottom + 14);
    ctx.fillText('90°', corrLeft + corrW * 0.25, corrBottom + 14);
    ctx.fillText('180°', corrLeft + corrW * 0.5, corrBottom + 14);
    ctx.fillText('270°', corrLeft + corrW * 0.75, corrBottom + 14);
    ctx.fillText('360°', corrRight, corrBottom + 14);
    ctx.fillText('Measurement angle φ of B', corrLeft + corrW / 2, corrBottom + 28);
    ctx.textAlign = 'left';

    // Tick marks on x axis
    for (let deg = 0; deg <= 360; deg += 90) {
      const x = corrLeft + (deg / 360) * corrW;
      ctx.strokeStyle = axisColor;
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(x, corrBottom);
      ctx.lineTo(x, corrBottom + 4);
      ctx.stroke();
    }

    // P(up_B | up_A at theta) = sin^2((phi - theta) / 2)
    // Plot as function of phi
    ctx.beginPath();
    ctx.strokeStyle = colorCorr;
    ctx.lineWidth = 2.5;
    for (let px = 0; px <= corrW; px++) {
      const phiPlot = (px / corrW) * 2 * Math.PI;
      const prob = Math.sin((phiPlot - theta) / 2) ** 2;
      const x = corrLeft + px;
      const y = corrBottom - prob * corrH;
      px === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    }
    ctx.stroke();

    // Mark current phi on the curve
    const currentProb = Math.sin((phi - theta) / 2) ** 2;
    const dotX = corrLeft + (phiDeg / 360) * corrW;
    const dotY = corrBottom - currentProb * corrH;

    // Vertical line from axis to dot
    ctx.strokeStyle = colorB;
    ctx.lineWidth = 1;
    ctx.setLineDash([3, 3]);
    ctx.beginPath();
    ctx.moveTo(dotX, corrBottom);
    ctx.lineTo(dotX, dotY);
    ctx.stroke();
    ctx.setLineDash([]);

    // Dot
    ctx.beginPath();
    ctx.fillStyle = colorB;
    ctx.arc(dotX, dotY, 5, 0, Math.PI * 2);
    ctx.fill();

    // Probability readout
    ctx.fillStyle = textColor;
    ctx.font = '12px system-ui';
    ctx.textAlign = 'center';
    ctx.fillText(`P(↑) = ${currentProb.toFixed(3)}`, corrLeft + corrW / 2, corrBottom + 48);

    // Mark theta position on x axis
    const thetaPx = corrLeft + (thetaDeg / 360) * corrW;
    ctx.strokeStyle = colorA;
    ctx.lineWidth = 1.5;
    ctx.beginPath();
    ctx.moveTo(thetaPx, corrTop);
    ctx.lineTo(thetaPx, corrBottom);
    ctx.stroke();
    ctx.fillStyle = colorA;
    ctx.font = '9px system-ui';
    ctx.fillText(`θ=${thetaDeg}°`, thetaPx + 3, corrTop + 12);

    // Mark theta + 180 (anti-correlated angle)
    const antiDeg = (thetaDeg + 180) % 360;
    const antiPx = corrLeft + (antiDeg / 360) * corrW;
    ctx.strokeStyle = colorA;
    ctx.lineWidth = 1;
    ctx.setLineDash([3, 3]);
    ctx.beginPath();
    ctx.moveTo(antiPx, corrTop);
    ctx.lineTo(antiPx, corrBottom);
    ctx.stroke();
    ctx.setLineDash([]);
    ctx.fillStyle = colorA;
    ctx.fillText(`θ+180°`, antiPx + 3, corrTop + 24);

    ctx.textAlign = 'left';

    // Annotation: perfect anti-correlation note
    const diffDeg = Math.abs(((phiDeg - thetaDeg + 180) % 360) - 180);
    ctx.fillStyle = mutedColor;
    ctx.font = 'italic 10px system-ui';
    if (diffDeg < 5) {
      ctx.fillText('φ ≈ θ → P(↑) ≈ 0 — perfect anti-correlation', corrLeft, corrBottom + 58);
    } else if (Math.abs(diffDeg - 180) < 5) {
      ctx.fillText('φ ≈ θ+180° → P(↑) ≈ 1 — same direction as A', corrLeft, corrBottom + 58);
    } else if (Math.abs(diffDeg - 90) < 5) {
      ctx.fillText('φ ⊥ θ → P(↑) = ½ — no correlation', corrLeft, corrBottom + 58);
    }

    time += 0.016;
    if (isVisible) requestAnimationFrame(draw);
  }

  let isVisible = false;
  const observer = new IntersectionObserver(([entry]) => {
    const wasVisible = isVisible;
    isVisible = entry.isIntersecting;
    if (isVisible && !wasVisible) requestAnimationFrame(draw);
  }, { threshold: 0.1 });
  observer.observe(canvas.closest('.diagram-container')!);
</script>
