---
// EPR experiment spacetime diagram with retroconsistency interpretation.
// Static worldlines, two-headed arrows showing that the initial singlet
// boundary condition at t=0 must be consistent with future measurements.
// No spacelike communication required — consistency is enforced along
// each timelike worldline independently.
---
<div class="diagram-container">
  <div class="diagram-controls">
    <label>
      Measurement A (&theta;):
      <input type="range" id="epr-theta" min="0" max="360" step="1" value="0" />
      <span id="epr-theta-val">0°</span>
    </label>
    <label>
      Measurement B (&phi;):
      <input type="range" id="epr-phi" min="0" max="360" step="1" value="180" />
      <span id="epr-phi-val">180°</span>
    </label>
    <label>
      Measurement time:
      <input type="range" id="epr-mtime" min="0.2" max="0.8" step="0.05" value="0.5" />
    </label>
  </div>
  <canvas id="epr-experiment" width="800" height="600"></canvas>
</div>

<style>
  .diagram-container {
    margin: 2rem 0;
    padding: 1.5rem;
    background: var(--color-card-bg);
    border-radius: var(--border-radius);
    box-shadow: 0 2px 8px var(--color-card-shadow);
  }

  .diagram-controls {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .diagram-controls label {
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  canvas {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--border-radius);
  }
</style>

<script>
  const canvas = document.getElementById('epr-experiment') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const thetaSlider = document.getElementById('epr-theta') as HTMLInputElement;
  const thetaValEl = document.getElementById('epr-theta-val')!;
  const phiSlider = document.getElementById('epr-phi') as HTMLInputElement;
  const phiValEl = document.getElementById('epr-phi-val')!;
  const mtimeSlider = document.getElementById('epr-mtime') as HTMLInputElement;

  thetaSlider.addEventListener('input', () => { thetaValEl.textContent = thetaSlider.value + '°'; redraw(); });
  phiSlider.addEventListener('input', () => { phiValEl.textContent = phiSlider.value + '°'; redraw(); });
  mtimeSlider.addEventListener('input', redraw);

  function drawDoubleArrow(
    x1: number, y1: number, x2: number, y2: number,
    color: string, headSize: number
  ) {
    const dx = x2 - x1;
    const dy = y2 - y1;
    const len = Math.sqrt(dx * dx + dy * dy);
    const ux = dx / len;
    const uy = dy / len;
    const px = -uy; // perpendicular
    const py = ux;

    ctx.strokeStyle = color;
    ctx.fillStyle = color;
    ctx.lineWidth = 2;

    // Shaft (inset from tips)
    const inset = headSize + 2;
    ctx.beginPath();
    ctx.moveTo(x1 + ux * inset, y1 + uy * inset);
    ctx.lineTo(x2 - ux * inset, y2 - uy * inset);
    ctx.stroke();

    // Arrowhead at end (x2, y2)
    ctx.beginPath();
    ctx.moveTo(x2, y2);
    ctx.lineTo(x2 - ux * headSize + px * headSize * 0.4, y2 - uy * headSize + py * headSize * 0.4);
    ctx.lineTo(x2 - ux * headSize - px * headSize * 0.4, y2 - uy * headSize - py * headSize * 0.4);
    ctx.closePath();
    ctx.fill();

    // Arrowhead at start (x1, y1)
    ctx.beginPath();
    ctx.moveTo(x1, y1);
    ctx.lineTo(x1 + ux * headSize + px * headSize * 0.4, y1 + uy * headSize + py * headSize * 0.4);
    ctx.lineTo(x1 + ux * headSize - px * headSize * 0.4, y1 + uy * headSize - py * headSize * 0.4);
    ctx.closePath();
    ctx.fill();
  }

  function redraw() {
    const W = canvas.width;
    const H = canvas.height;
    const thetaDeg = parseFloat(thetaSlider.value);
    const phiDeg = parseFloat(phiSlider.value);
    const mTimeFrac = parseFloat(mtimeSlider.value);
    const theta = thetaDeg * Math.PI / 180;
    const phi = phiDeg * Math.PI / 180;

    const isDark = document.documentElement.getAttribute('data-theme') === 'ds9';

    ctx.clearRect(0, 0, W, H);
    ctx.fillStyle = isDark ? '#05050f' : '#fafafa';
    ctx.fillRect(0, 0, W, H);

    const colorA = isDark ? '#e8a640' : '#e63946';
    const colorB = isDark ? '#64b5f6' : '#457b9d';
    const colorSinglet = isDark ? '#cc99ff' : '#7c3aed';
    const colorRetro = isDark ? '#33cccc' : '#2a9d8f';
    const colorCorr = isDark ? '#33cccc' : '#2a9d8f';
    const textColor = isDark ? '#c8cad8' : '#1a1a1a';
    const mutedColor = isDark ? '#7a7e9a' : '#888';
    const axisColor = isDark ? '#1a1a4a' : '#e0e0e0';
    const lightconeColor = isDark ? 'rgba(255,255,255,0.04)' : 'rgba(0,0,0,0.02)';

    // Layout
    const stW = W * 0.55;
    const corrX = W * 0.6;
    const corrW = W * 0.37;
    const margin = { top: 20, bottom: 40 };
    const stH = H - margin.top - margin.bottom;

    const originX = stW / 2;
    const originY = H - margin.bottom;
    const topY = margin.top;

    // Worldline geometry
    const velocity = 0.35;
    const particleAx = (t: number) => originX - velocity * t * stH * 0.45;
    const particleBx = (t: number) => originX + velocity * t * stH * 0.45;
    const timeToY = (t: number) => originY - t * stH;

    const mY = timeToY(mTimeFrac);
    const mAx = particleAx(mTimeFrac);
    const mBx = particleBx(mTimeFrac);
    const topAx = particleAx(1);
    const topBx = particleBx(1);

    // === Spacetime diagram ===

    // Light cone
    ctx.fillStyle = lightconeColor;
    ctx.beginPath();
    ctx.moveTo(originX, originY);
    ctx.lineTo(originX - stH * 0.45, topY);
    ctx.lineTo(originX + stH * 0.45, topY);
    ctx.closePath();
    ctx.fill();

    ctx.strokeStyle = isDark ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.06)';
    ctx.lineWidth = 1;
    ctx.setLineDash([4, 6]);
    ctx.beginPath();
    ctx.moveTo(originX, originY);
    ctx.lineTo(originX - stH * 0.45, topY);
    ctx.stroke();
    ctx.beginPath();
    ctx.moveTo(originX, originY);
    ctx.lineTo(originX + stH * 0.45, topY);
    ctx.stroke();
    ctx.setLineDash([]);

    // Axes
    ctx.strokeStyle = axisColor;
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(originX, originY + 5);
    ctx.lineTo(originX, topY);
    ctx.stroke();
    ctx.beginPath();
    ctx.moveTo(15, originY);
    ctx.lineTo(stW - 5, originY);
    ctx.stroke();

    ctx.fillStyle = mutedColor;
    ctx.font = '11px system-ui';
    ctx.fillText('t', originX + 6, topY + 5);
    ctx.fillText('x', stW - 10, originY + 15);

    // Worldline A — static straight line
    ctx.strokeStyle = colorA;
    ctx.lineWidth = 2.5;
    ctx.beginPath();
    ctx.moveTo(originX, originY);
    ctx.lineTo(topAx, topY);
    ctx.stroke();

    // Worldline B — static straight line
    ctx.strokeStyle = colorB;
    ctx.lineWidth = 2.5;
    ctx.beginPath();
    ctx.moveTo(originX, originY);
    ctx.lineTo(topBx, topY);
    ctx.stroke();

    // === Retroconsistency double arrows ===

    // Arrow along branch A: from singlet (origin) to measurement A
    // Offset slightly to the left of the worldline
    const offsetA = -12;
    const offsetB = 12;

    // Branch A: origin → measurement
    const aOrigX = originX + offsetA * 0.7;
    const aOrigY = originY - 8;
    const aMeasX = mAx + offsetA;
    const aMeasY = mY + 4;
    drawDoubleArrow(aOrigX, aOrigY, aMeasX, aMeasY, colorRetro, 7);

    // Branch A: measurement → future
    const aTopX = topAx + offsetA;
    const aTopY = topY + 8;
    drawDoubleArrow(aMeasX, aMeasY - 8, aTopX, aTopY, colorRetro, 7);

    // Branch B: origin → measurement
    const bOrigX = originX - offsetA * 0.7;
    const bOrigY = originY - 8;
    const bMeasX = mBx + offsetB;
    const bMeasY = mY + 4;
    drawDoubleArrow(bOrigX, bOrigY, bMeasX, bMeasY, colorRetro, 7);

    // Branch B: measurement → future
    const bTopX = topBx + offsetB;
    const bTopY = topY + 8;
    drawDoubleArrow(bMeasX, bMeasY - 8, bTopX, bTopY, colorRetro, 7);

    // Retroconsistency labels
    ctx.fillStyle = colorRetro;
    ctx.font = 'italic 9px system-ui';
    ctx.save();
    // Label on branch A
    const aLabelX = (aOrigX + aMeasX) / 2 - 8;
    const aLabelY = (aOrigY + aMeasY) / 2;
    ctx.translate(aLabelX, aLabelY);
    const aAngle = Math.atan2(aMeasY - aOrigY, aMeasX - aOrigX);
    ctx.rotate(aAngle);
    ctx.fillText('retroconsistency', -40, -6);
    ctx.restore();

    ctx.save();
    const bLabelX = (bOrigX + bMeasX) / 2 + 8;
    const bLabelY = (bOrigY + bMeasY) / 2;
    ctx.translate(bLabelX, bLabelY);
    const bAngle = Math.atan2(bMeasY - bOrigY, bMeasX - bOrigX);
    ctx.rotate(bAngle);
    ctx.fillText('retroconsistency', -40, -6);
    ctx.restore();

    // Singlet creation event
    ctx.beginPath();
    ctx.fillStyle = colorSinglet;
    ctx.arc(originX, originY, 7, 0, Math.PI * 2);
    ctx.fill();
    ctx.fillStyle = colorSinglet;
    ctx.font = '11px system-ui';
    ctx.textAlign = 'center';
    ctx.fillText('Singlet |ψ⟩ at t = 0', originX, originY + 20);
    ctx.font = '9px system-ui';
    ctx.fillText('(initial boundary condition)', originX, originY + 32);
    ctx.textAlign = 'left';

    // Measurement event A
    ctx.fillStyle = colorA;
    ctx.beginPath();
    ctx.arc(mAx, mY, 5, 0, Math.PI * 2);
    ctx.fill();

    // Spin arrow for A
    const arrowLen = 22;
    const aArrowX = mAx - 35;
    const aArrowY = mY;
    ctx.strokeStyle = colorA;
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.moveTo(aArrowX - arrowLen / 2 * Math.cos(theta), aArrowY + arrowLen / 2 * Math.sin(theta));
    ctx.lineTo(aArrowX + arrowLen / 2 * Math.cos(theta), aArrowY - arrowLen / 2 * Math.sin(theta));
    ctx.stroke();
    const tipAx2 = aArrowX + arrowLen / 2 * Math.cos(theta);
    const tipAy2 = aArrowY - arrowLen / 2 * Math.sin(theta);
    ctx.beginPath();
    ctx.moveTo(tipAx2, tipAy2);
    ctx.lineTo(tipAx2 - 6 * Math.cos(theta - 0.4), tipAy2 + 6 * Math.sin(theta - 0.4));
    ctx.moveTo(tipAx2, tipAy2);
    ctx.lineTo(tipAx2 - 6 * Math.cos(theta + 0.4), tipAy2 + 6 * Math.sin(theta + 0.4));
    ctx.stroke();

    ctx.fillStyle = colorA;
    ctx.font = '10px system-ui';
    ctx.textAlign = 'center';
    ctx.fillText(`↑ θ=${thetaDeg}°`, mAx - 35, mY - 18);
    ctx.fillText('Meas. A', mAx, mY + 18);
    ctx.textAlign = 'left';

    // Measurement event B
    ctx.fillStyle = colorB;
    ctx.beginPath();
    ctx.arc(mBx, mY, 5, 0, Math.PI * 2);
    ctx.fill();

    const bArrowX = mBx + 35;
    const bArrowY = mY;
    ctx.strokeStyle = colorB;
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.moveTo(bArrowX - arrowLen / 2 * Math.cos(phi), bArrowY + arrowLen / 2 * Math.sin(phi));
    ctx.lineTo(bArrowX + arrowLen / 2 * Math.cos(phi), bArrowY - arrowLen / 2 * Math.sin(phi));
    ctx.stroke();
    const tipBx2 = bArrowX + arrowLen / 2 * Math.cos(phi);
    const tipBy2 = bArrowY - arrowLen / 2 * Math.sin(phi);
    ctx.beginPath();
    ctx.moveTo(tipBx2, tipBy2);
    ctx.lineTo(tipBx2 - 6 * Math.cos(phi - 0.4), tipBy2 + 6 * Math.sin(phi - 0.4));
    ctx.moveTo(tipBx2, tipBy2);
    ctx.lineTo(tipBx2 - 6 * Math.cos(phi + 0.4), tipBy2 + 6 * Math.sin(phi + 0.4));
    ctx.stroke();

    ctx.fillStyle = colorB;
    ctx.font = '10px system-ui';
    ctx.textAlign = 'center';
    ctx.fillText(`φ=${phiDeg}°`, mBx + 35, mY - 18);
    ctx.fillText('Meas. B', mBx, mY + 18);
    ctx.textAlign = 'left';

    // Spacelike separation — with X through it (no communication)
    ctx.strokeStyle = mutedColor;
    ctx.lineWidth = 1;
    ctx.setLineDash([3, 3]);
    ctx.beginPath();
    ctx.moveTo(mAx + 8, mY);
    ctx.lineTo(mBx - 8, mY);
    ctx.stroke();
    ctx.setLineDash([]);

    // X mark in the middle — no spacelike signal
    const midSx = (mAx + mBx) / 2;
    ctx.strokeStyle = isDark ? '#ff4444' : '#dc2626';
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.moveTo(midSx - 6, mY - 6);
    ctx.lineTo(midSx + 6, mY + 6);
    ctx.stroke();
    ctx.beginPath();
    ctx.moveTo(midSx + 6, mY - 6);
    ctx.lineTo(midSx - 6, mY + 6);
    ctx.stroke();

    ctx.fillStyle = isDark ? '#ff4444' : '#dc2626';
    ctx.font = '9px system-ui';
    ctx.textAlign = 'center';
    ctx.fillText('no spacelike signal', midSx, mY - 10);
    ctx.textAlign = 'left';

    // Worldline labels at top
    ctx.fillStyle = colorA;
    ctx.font = '10px system-ui';
    ctx.textAlign = 'center';
    ctx.fillText('A', topAx, topY - 5);
    ctx.fillStyle = colorB;
    ctx.fillText('B', topBx, topY - 5);
    ctx.textAlign = 'left';

    // === Right panel: correlation plot ===

    const corrTop = margin.top + 20;
    const corrBottom = H - margin.bottom - 60;
    const corrH = corrBottom - corrTop;
    const corrLeft = corrX;
    const corrRight = corrX + corrW;

    ctx.fillStyle = textColor;
    ctx.font = '12px system-ui';
    ctx.textAlign = 'center';
    ctx.fillText('P(↑) for particle B', corrLeft + corrW / 2, corrTop - 8);
    ctx.textAlign = 'left';

    // Axes
    ctx.strokeStyle = axisColor;
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(corrLeft, corrTop);
    ctx.lineTo(corrLeft, corrBottom);
    ctx.lineTo(corrRight, corrBottom);
    ctx.stroke();

    ctx.fillStyle = mutedColor;
    ctx.font = '10px system-ui';
    ctx.fillText('1', corrLeft - 14, corrTop + 4);
    ctx.fillText('0', corrLeft - 14, corrBottom + 4);
    ctx.fillText('½', corrLeft - 14, corrTop + corrH / 2 + 4);

    // Half line
    ctx.strokeStyle = axisColor;
    ctx.lineWidth = 0.5;
    ctx.setLineDash([4, 4]);
    ctx.beginPath();
    ctx.moveTo(corrLeft, corrTop + corrH / 2);
    ctx.lineTo(corrRight, corrTop + corrH / 2);
    ctx.stroke();
    ctx.setLineDash([]);

    // X axis labels
    ctx.fillStyle = mutedColor;
    ctx.font = '10px system-ui';
    ctx.textAlign = 'center';
    ctx.fillText('0°', corrLeft, corrBottom + 14);
    ctx.fillText('90°', corrLeft + corrW * 0.25, corrBottom + 14);
    ctx.fillText('180°', corrLeft + corrW * 0.5, corrBottom + 14);
    ctx.fillText('270°', corrLeft + corrW * 0.75, corrBottom + 14);
    ctx.fillText('360°', corrRight, corrBottom + 14);
    ctx.fillText('Measurement angle φ of B', corrLeft + corrW / 2, corrBottom + 28);
    ctx.textAlign = 'left';

    for (let deg = 0; deg <= 360; deg += 90) {
      const x = corrLeft + (deg / 360) * corrW;
      ctx.strokeStyle = axisColor;
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(x, corrBottom);
      ctx.lineTo(x, corrBottom + 4);
      ctx.stroke();
    }

    // P(up_B | up_A at theta) = sin^2((phi - theta) / 2)
    ctx.beginPath();
    ctx.strokeStyle = colorCorr;
    ctx.lineWidth = 2.5;
    for (let px = 0; px <= corrW; px++) {
      const phiPlot = (px / corrW) * 2 * Math.PI;
      const prob = Math.sin((phiPlot - theta) / 2) ** 2;
      const x = corrLeft + px;
      const y = corrBottom - prob * corrH;
      px === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    }
    ctx.stroke();

    // Current phi marker
    const currentProb = Math.sin((phi - theta) / 2) ** 2;
    const dotX = corrLeft + (phiDeg / 360) * corrW;
    const dotY = corrBottom - currentProb * corrH;

    ctx.strokeStyle = colorB;
    ctx.lineWidth = 1;
    ctx.setLineDash([3, 3]);
    ctx.beginPath();
    ctx.moveTo(dotX, corrBottom);
    ctx.lineTo(dotX, dotY);
    ctx.stroke();
    ctx.setLineDash([]);

    ctx.beginPath();
    ctx.fillStyle = colorB;
    ctx.arc(dotX, dotY, 5, 0, Math.PI * 2);
    ctx.fill();

    // Theta marker
    const thetaPx = corrLeft + (thetaDeg / 360) * corrW;
    ctx.strokeStyle = colorA;
    ctx.lineWidth = 1.5;
    ctx.beginPath();
    ctx.moveTo(thetaPx, corrTop);
    ctx.lineTo(thetaPx, corrBottom);
    ctx.stroke();
    ctx.fillStyle = colorA;
    ctx.font = '9px system-ui';
    ctx.fillText(`θ=${thetaDeg}°`, thetaPx + 3, corrTop + 12);

    // Anti-correlated angle
    const antiDeg = (thetaDeg + 180) % 360;
    const antiPx = corrLeft + (antiDeg / 360) * corrW;
    ctx.strokeStyle = colorA;
    ctx.lineWidth = 1;
    ctx.setLineDash([3, 3]);
    ctx.beginPath();
    ctx.moveTo(antiPx, corrTop);
    ctx.lineTo(antiPx, corrBottom);
    ctx.stroke();
    ctx.setLineDash([]);
    ctx.fillStyle = colorA;
    ctx.fillText(`θ+180°`, antiPx + 3, corrTop + 24);

    // Probability readout
    ctx.fillStyle = textColor;
    ctx.font = '12px system-ui';
    ctx.textAlign = 'center';
    ctx.fillText(`P(↑) = ${currentProb.toFixed(3)}`, corrLeft + corrW / 2, corrBottom + 48);
    ctx.textAlign = 'left';

    // Annotation
    const diffDeg = Math.abs(((phiDeg - thetaDeg + 180) % 360) - 180);
    ctx.fillStyle = mutedColor;
    ctx.font = 'italic 10px system-ui';
    if (diffDeg < 5) {
      ctx.fillText('φ ≈ θ → P(↑) ≈ 0 — perfect anti-correlation', corrLeft, corrBottom + 58);
    } else if (Math.abs(diffDeg - 180) < 5) {
      ctx.fillText('φ ≈ θ+180° → P(↑) ≈ 1 — same direction as A', corrLeft, corrBottom + 58);
    } else if (Math.abs(diffDeg - 90) < 5) {
      ctx.fillText('φ ⊥ θ → P(↑) = ½ — no correlation', corrLeft, corrBottom + 58);
    }
  }

  // Initial draw and observer
  let isVisible = false;
  const observer = new IntersectionObserver(([entry]) => {
    isVisible = entry.isIntersecting;
    if (isVisible) redraw();
  }, { threshold: 0.1 });
  observer.observe(canvas.closest('.diagram-container')!);
  redraw();
</script>
