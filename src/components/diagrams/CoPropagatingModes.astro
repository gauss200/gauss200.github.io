---
// Co-propagating coupled modes: two modes traveling in the same direction
// through a shared medium, exchanging energy via coupling.
// Shows the superposition and beating of the two normal modes.
---
<div class="diagram-container">
  <h3>Co-Propagating Coupled Modes</h3>
  <p class="diagram-desc">
    Two modes travel in the same direction through a coupled system. Their superposition
    creates a beating pattern — energy sloshes between Mode A and Mode B at a rate set
    by the coupling &kappa; and detuning &Delta;&beta;.
  </p>
  <div class="diagram-controls">
    <label>
      Coupling (&kappa;):
      <input type="range" id="cp-modes-kappa" min="0.2" max="4" step="0.1" value="1.5" />
      <span id="cp-modes-kappa-val">1.5</span>
    </label>
    <label>
      Detuning (&Delta;&beta;):
      <input type="range" id="cp-modes-detuning" min="0" max="3" step="0.1" value="0" />
      <span id="cp-modes-detuning-val">0.0</span>
    </label>
    <label>
      <input type="checkbox" id="cp-modes-show-envelope" checked /> Show envelope
    </label>
    <label>
      <input type="checkbox" id="cp-modes-show-normal" /> Show normal modes
    </label>
  </div>
  <canvas id="copropagating-modes" width="800" height="400"></canvas>
</div>

<style>
  .diagram-container {
    margin: 2rem 0;
    padding: 1.5rem;
    background: var(--color-card-bg);
    border-radius: var(--border-radius);
    box-shadow: 0 2px 8px var(--color-card-shadow);
  }

  .diagram-desc {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .diagram-controls {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .diagram-controls label {
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  canvas {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--border-radius);
  }
</style>

<script>
  const canvas = document.getElementById('copropagating-modes') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const kappaSlider = document.getElementById('cp-modes-kappa') as HTMLInputElement;
  const kappaVal = document.getElementById('cp-modes-kappa-val')!;
  const detuningSlider = document.getElementById('cp-modes-detuning') as HTMLInputElement;
  const detuningVal = document.getElementById('cp-modes-detuning-val')!;
  const showEnvelope = document.getElementById('cp-modes-show-envelope') as HTMLInputElement;
  const showNormal = document.getElementById('cp-modes-show-normal') as HTMLInputElement;

  let time = 0;

  kappaSlider.addEventListener('input', () => { kappaVal.textContent = parseFloat(kappaSlider.value).toFixed(1); });
  detuningSlider.addEventListener('input', () => { detuningVal.textContent = parseFloat(detuningSlider.value).toFixed(1); });

  function draw() {
    const W = canvas.width;
    const H = canvas.height;
    const kappa = parseFloat(kappaSlider.value);
    const deltaBeta = parseFloat(detuningSlider.value);

    const isDark = document.documentElement.getAttribute('data-theme') === 'ds9';

    ctx.clearRect(0, 0, W, H);
    ctx.fillStyle = isDark ? '#0a0a12' : '#fafaf8';
    ctx.fillRect(0, 0, W, H);

    // CMT: effective coupling frequency
    const omega = Math.sqrt(kappa * kappa + deltaBeta * deltaBeta);
    const transferMax = (kappa * kappa) / (omega * omega);

    // Average propagation constant
    const betaAvg = 10;
    const k0 = 15; // carrier wave frequency

    const margin = { left: 15, right: 15, top: 10, bottom: 10 };
    const plotW = W - margin.left - margin.right;

    // Three rows: Mode A, Superposition, Mode B
    const rowH = (H - margin.top - margin.bottom - 20) / 3;
    const rowY = [margin.top, margin.top + rowH + 10, margin.top + 2 * (rowH + 10)];

    const colorA = isDark ? '#e8a640' : '#e63946';
    const colorB = isDark ? '#64b5f6' : '#457b9d';
    const colorSuper = isDark ? '#cc99ff' : '#6b21a8';
    const colorEnv = isDark ? 'rgba(232, 166, 64, 0.3)' : 'rgba(0,0,0,0.12)';
    const colorNormalS = isDark ? '#33cccc' : '#2a9d8f';
    const colorNormalA = isDark ? '#ff6699' : '#c2185b';
    const textColor = isDark ? '#c8cad8' : '#1a1a1a';
    const mutedColor = isDark ? '#7a7e9a' : '#888';
    const axisColor = isDark ? '#2a2d4a' : '#ddd';

    // Draw each row
    const rows = [
      { label: 'Mode A — amplitude', color: colorA, ampFn: (z: number) => {
        const envA = Math.sqrt(Math.cos(omega * z) ** 2 * transferMax + (1 - transferMax));
        return envA;
      }},
      { label: 'Superposition (A + B)', color: colorSuper, ampFn: null },
      { label: 'Mode B — amplitude', color: colorB, ampFn: (z: number) => {
        const envB = Math.sqrt(Math.sin(omega * z) ** 2 * transferMax);
        return envB;
      }},
    ];

    for (let r = 0; r < 3; r++) {
      const y0 = rowY[r];
      const midY = y0 + rowH / 2;
      const ampScale = rowH * 0.4;

      // Axis line
      ctx.strokeStyle = axisColor;
      ctx.lineWidth = 0.5;
      ctx.beginPath();
      ctx.moveTo(margin.left, midY);
      ctx.lineTo(margin.left + plotW, midY);
      ctx.stroke();

      // Label
      ctx.fillStyle = mutedColor;
      ctx.font = '11px system-ui';
      ctx.fillText(rows[r].label, margin.left + 5, y0 + 12);

      if (r === 1) {
        // Superposition row: draw A + B combined
        ctx.beginPath();
        ctx.strokeStyle = colorSuper;
        ctx.lineWidth = 1.5;
        for (let px = 0; px <= plotW; px++) {
          const z = (px / plotW) * 8;
          const envA = Math.cos(omega * z) ** 2 * transferMax + (1 - transferMax);
          const envB = Math.sin(omega * z) ** 2 * transferMax;
          const waveA = Math.sqrt(envA) * Math.sin(k0 * z - time * 3);
          const waveB = Math.sqrt(envB) * Math.sin(k0 * z - time * 3 + deltaBeta * z);
          const combined = (waveA + waveB) * 0.6;
          const x = margin.left + px;
          const y = midY - combined * ampScale;
          px === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
        }
        ctx.stroke();
      } else {
        // Mode A or B
        const ampFn = rows[r].ampFn!;
        const color = rows[r].color;
        const phaseOffset = r === 2 ? deltaBeta : 0;

        // Envelope
        if (showEnvelope.checked) {
          ctx.beginPath();
          ctx.strokeStyle = colorEnv;
          ctx.lineWidth = 1;
          for (let px = 0; px <= plotW; px++) {
            const z = (px / plotW) * 8;
            const env = ampFn(z);
            const x = margin.left + px;
            px === 0 ? ctx.moveTo(x, midY - env * ampScale) : ctx.lineTo(x, midY - env * ampScale);
          }
          ctx.stroke();
          ctx.beginPath();
          for (let px = 0; px <= plotW; px++) {
            const z = (px / plotW) * 8;
            const env = ampFn(z);
            const x = margin.left + px;
            px === 0 ? ctx.moveTo(x, midY + env * ampScale) : ctx.lineTo(x, midY + env * ampScale);
          }
          ctx.stroke();
        }

        // Wave
        ctx.beginPath();
        ctx.strokeStyle = color;
        ctx.lineWidth = 1.5;
        for (let px = 0; px <= plotW; px++) {
          const z = (px / plotW) * 8;
          const env = ampFn(z);
          const wave = env * Math.sin(k0 * z + phaseOffset * z - time * 3);
          const x = margin.left + px;
          const y = midY - wave * ampScale;
          px === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
        }
        ctx.stroke();
      }

      // Normal modes overlay
      if (showNormal.checked && r !== 1) {
        // Symmetric mode (same phase)
        ctx.beginPath();
        ctx.strokeStyle = colorNormalS;
        ctx.lineWidth = 0.8;
        ctx.globalAlpha = 0.5;
        for (let px = 0; px <= plotW; px++) {
          const z = (px / plotW) * 8;
          const betaS = betaAvg + omega;
          const wave = 0.5 * Math.sin(betaS * z - time * 3);
          const x = margin.left + px;
          const y = midY - wave * ampScale;
          px === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
        }
        ctx.stroke();

        // Antisymmetric mode (opposite phase)
        ctx.beginPath();
        ctx.strokeStyle = colorNormalA;
        for (let px = 0; px <= plotW; px++) {
          const z = (px / plotW) * 8;
          const betaA = betaAvg - omega;
          const sign = r === 0 ? 1 : -1;
          const wave = sign * 0.5 * Math.sin(betaA * z - time * 3);
          const x = margin.left + px;
          const y = midY - wave * ampScale;
          px === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
        }
        ctx.stroke();
        ctx.globalAlpha = 1;
      }
    }

    // Propagation arrow
    ctx.fillStyle = mutedColor;
    ctx.font = '11px system-ui';
    ctx.fillText('z →', W - 35, H - 5);

    // Normal mode legend
    if (showNormal.checked) {
      const ly = H - 18;
      ctx.strokeStyle = colorNormalS;
      ctx.lineWidth = 1.5;
      ctx.globalAlpha = 0.6;
      ctx.beginPath(); ctx.moveTo(margin.left + 5, ly); ctx.lineTo(margin.left + 25, ly); ctx.stroke();
      ctx.globalAlpha = 1;
      ctx.fillStyle = mutedColor;
      ctx.fillText('Symmetric', margin.left + 30, ly + 4);

      ctx.strokeStyle = colorNormalA;
      ctx.lineWidth = 1.5;
      ctx.globalAlpha = 0.6;
      ctx.beginPath(); ctx.moveTo(margin.left + 110, ly); ctx.lineTo(margin.left + 130, ly); ctx.stroke();
      ctx.globalAlpha = 1;
      ctx.fillStyle = mutedColor;
      ctx.fillText('Antisymmetric', margin.left + 135, ly + 4);
    }

    time += 0.016;
    requestAnimationFrame(draw);
  }

  draw();
</script>
