---
// Retrocausal self-consistency loop in coupled mode theory.
// Two modes propagate along z (representing time):
//   ψ  (forward-time, propagating +z)
//   ψ* (reverse-time, propagating -z)
// They are coupled by an interaction κ that transfers amplitude between them.
// Boundary conditions at z=0 (initial measurement) and z=L (final measurement)
// constrain the system. A self-consistent solution requires that the round-trip
// amplitude — forward through ψ, reflected into ψ* at the final BC, backward
// through ψ*, reflected into ψ at the initial BC — returns to itself.
---
<div class="diagram-container">
  <div class="diagram-controls">
    <label>
      Coupling (&kappa;):
      <input type="range" id="rc-kappa" min="0" max="3" step="0.05" value="0.8" />
      <span id="rc-kappa-val">0.80</span>
    </label>
    <label>
      Time span (L):
      <input type="range" id="rc-length" min="1" max="10" step="0.25" value="5" />
      <span id="rc-length-val">5.00</span>
    </label>
    <label>
      Initial measurement strength:
      <input type="range" id="rc-r0" min="0" max="1" step="0.05" value="0.9" />
      <span id="rc-r0-val">0.90</span>
    </label>
    <label>
      Final measurement strength:
      <input type="range" id="rc-rL" min="0" max="1" step="0.05" value="0.9" />
      <span id="rc-rL-val">0.90</span>
    </label>
  </div>
  <canvas id="retrocausal-loop" width="800" height="520"></canvas>
</div>

<style>
  .diagram-container {
    margin: 2rem 0;
    padding: 1.5rem;
    background: var(--color-card-bg);
    border-radius: var(--border-radius);
    box-shadow: 0 2px 8px var(--color-card-shadow);
  }
  .diagram-controls {
    display: flex;
    gap: 1.25rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .diagram-controls label {
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  canvas {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--border-radius);
  }
</style>

<script>
  const canvas = document.getElementById('retrocausal-loop') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const kappaSlider = document.getElementById('rc-kappa') as HTMLInputElement;
  const kappaValEl = document.getElementById('rc-kappa-val')!;
  const lengthSlider = document.getElementById('rc-length') as HTMLInputElement;
  const lengthValEl = document.getElementById('rc-length-val')!;
  const r0Slider = document.getElementById('rc-r0') as HTMLInputElement;
  const r0ValEl = document.getElementById('rc-r0-val')!;
  const rLSlider = document.getElementById('rc-rL') as HTMLInputElement;
  const rLValEl = document.getElementById('rc-rL-val')!;

  let time = 0;

  kappaSlider.addEventListener('input', () => kappaValEl.textContent = parseFloat(kappaSlider.value).toFixed(2));
  lengthSlider.addEventListener('input', () => lengthValEl.textContent = parseFloat(lengthSlider.value).toFixed(2));
  r0Slider.addEventListener('input', () => r0ValEl.textContent = parseFloat(r0Slider.value).toFixed(2));
  rLSlider.addEventListener('input', () => rLValEl.textContent = parseFloat(rLSlider.value).toFixed(2));

  // Physics:
  // Counter-propagating modes ψ (forward, +z) and ψ* (backward, -z) coupled by κ.
  //   dψ/dz  = -iβψ + iκψ*
  //   dψ*/dz =  iβψ* - iκψ    (ψ* propagates in -z)
  //
  // Boundary conditions model measurements:
  //   At z=0: ψ(0) = r₀ · ψ*(0)   (initial measurement reflects ψ* into ψ with strength r₀)
  //   At z=L: ψ*(L) = rL · ψ(L)   (final measurement reflects ψ into ψ* with strength rL)
  //
  // Self-consistency: start with ψ(0)=1, propagate forward to get ψ(L),
  // apply final BC to get ψ*(L), propagate backward to get ψ*(0),
  // apply initial BC to get new ψ(0). Must return to same value.
  //
  // Solution: γ = sqrt(κ²), for real κ and β=0 simplification:
  //   ψ(z)  = A cosh(κ(L-z)) + B sinh(κ(L-z))  (counter-prop CMT)
  //   ψ*(z) = C cosh(κz) + D sinh(κz)
  // With BCs determining A,B,C,D.

  function solve(kappa: number, L: number, r0: number, rL: number, nPts: number):
    { psiF: number[]; psiB: number[]; consistent: number } {

    const psiF: number[] = [];
    const psiB: number[] = [];

    // Numerical approach: propagate coupled equations
    // Use transfer matrix for counter-propagating modes:
    //   [ψ(z)]    [cosh(κz)    sinh(κz) ] [ψ(0) ]
    //   [ψ*(z)] = [sinh(κz)    cosh(κz) ] [ψ*(0)]
    //
    // But ψ* propagates backward, so the coupling is:
    //   ψ(z) = ψ(0)cosh(κz) + ψ*(0)sinh(κz)  (picking up from ψ*)
    //   ψ*(z) = ψ(0)sinh(κz) + ψ*(0)cosh(κz)  (ψ* grows from coupling to ψ)
    //
    // BC at z=0: ψ(0) = r0 * ψ*(0)  → set ψ*(0) = 1, ψ(0) = r0
    // BC at z=L: ψ*(L) = rL * ψ(L)

    // Start: ψ*(0) = 1 (normalize), ψ(0) = r0
    const psi0 = r0;
    const psiStar0 = 1;

    // Propagate to z=L
    const psiL = psi0 * Math.cosh(kappa * L) + psiStar0 * Math.sinh(kappa * L);
    const psiStarL = psi0 * Math.sinh(kappa * L) + psiStar0 * Math.cosh(kappa * L);

    // Check final BC: ψ*(L) should equal rL * ψ(L)
    const requiredPsiStarL = rL * psiL;
    const consistency = psiStarL > 0.001 ? requiredPsiStarL / psiStarL : 0;

    // For display: use the actual solution with both BCs enforced.
    // Solve the full system: find ψ*(0) such that BC at both ends holds.
    // ψ(0) = r0 * ψ*(0)
    // ψ*(L) = rL * ψ(L)
    // ψ(L) = r0*ψ*(0)*cosh(κL) + ψ*(0)*sinh(κL) = ψ*(0)*(r0*cosh(κL) + sinh(κL))
    // ψ*(L) = r0*ψ*(0)*sinh(κL) + ψ*(0)*cosh(κL) = ψ*(0)*(r0*sinh(κL) + cosh(κL))
    // BC: ψ*(L) = rL * ψ(L)
    // ψ*(0)*(r0*sinh(κL) + cosh(κL)) = rL * ψ*(0)*(r0*cosh(κL) + sinh(κL))
    // r0*sinh(κL) + cosh(κL) = rL*(r0*cosh(κL) + sinh(κL))
    // This is the self-consistency condition (independent of ψ*(0)).
    const lhs = r0 * Math.sinh(kappa * L) + Math.cosh(kappa * L);
    const rhs = rL * (r0 * Math.cosh(kappa * L) + Math.sinh(kappa * L));
    const selfConsistency = Math.abs(rhs) > 0.001 ? lhs / rhs : 0;

    // Use normalized solution: ψ*(0) = 1
    for (let i = 0; i <= nPts; i++) {
      const z = (i / nPts) * L;
      const fwd = r0 * Math.cosh(kappa * z) + Math.sinh(kappa * z);
      const bwd = r0 * Math.sinh(kappa * z) + Math.cosh(kappa * z);
      psiF.push(fwd);
      psiB.push(bwd);
    }

    // Normalize so max = 1
    const maxVal = Math.max(...psiF.map(Math.abs), ...psiB.map(Math.abs), 0.001);
    for (let i = 0; i <= nPts; i++) {
      psiF[i] /= maxVal;
      psiB[i] /= maxVal;
    }

    return { psiF, psiB, consistent: selfConsistency };
  }

  function drawArrow(x1: number, y1: number, x2: number, y2: number,
    color: string, width: number, headSize: number) {
    const dx = x2 - x1;
    const dy = y2 - y1;
    const len = Math.sqrt(dx * dx + dy * dy);
    if (len < 2) return;
    const ux = dx / len;
    const uy = dy / len;

    ctx.strokeStyle = color;
    ctx.lineWidth = width;
    ctx.beginPath();
    ctx.moveTo(x1, y1);
    ctx.lineTo(x2 - ux * headSize * 0.5, y2 - uy * headSize * 0.5);
    ctx.stroke();

    ctx.fillStyle = color;
    ctx.beginPath();
    ctx.moveTo(x2, y2);
    ctx.lineTo(x2 - ux * headSize - uy * headSize * 0.35, y2 - uy * headSize + ux * headSize * 0.35);
    ctx.lineTo(x2 - ux * headSize + uy * headSize * 0.35, y2 - uy * headSize - ux * headSize * 0.35);
    ctx.closePath();
    ctx.fill();
  }

  function draw() {
    const W = canvas.width;
    const H = canvas.height;
    const kappa = parseFloat(kappaSlider.value);
    const L = parseFloat(lengthSlider.value);
    const r0 = parseFloat(r0Slider.value);
    const rL = parseFloat(rLSlider.value);

    const isDark = document.documentElement.getAttribute('data-theme') === 'ds9';

    ctx.clearRect(0, 0, W, H);
    ctx.fillStyle = isDark ? '#05050f' : '#fafafa';
    ctx.fillRect(0, 0, W, H);

    const colorFwd = isDark ? '#e8a640' : '#e63946';
    const colorBwd = isDark ? '#64b5f6' : '#457b9d';
    const colorBC = isDark ? '#cc99ff' : '#7c3aed';
    const colorLoop = isDark ? '#33cccc' : '#2a9d8f';
    const textColor = isDark ? '#c8cad8' : '#1a1a1a';
    const mutedColor = isDark ? '#7a7e9a' : '#888';
    const axisColor = isDark ? '#1a1a4a' : '#e0e0e0';
    const bcFill = isDark ? 'rgba(204,153,255,0.08)' : 'rgba(124,58,237,0.05)';

    const margin = { left: 70, right: 30, top: 25, bottom: 40 };
    const plotW = W - margin.left - margin.right;
    const plotH = H - margin.top - margin.bottom;

    // Top half: waveguide diagram
    const wgH = plotH * 0.45;
    const wgTop = margin.top;
    // Bottom half: amplitude plot
    const ampTop = margin.top + wgH + 40;
    const ampH = plotH - wgH - 40;

    const nPts = 200;
    const { psiF, psiB, consistent } = solve(kappa, L, r0, rL, nPts);

    const zLeft = margin.left;
    const zRight = margin.left + plotW;

    // === Top: Waveguide / loop diagram ===

    const fwdY = wgTop + wgH * 0.3;
    const bwdY = wgTop + wgH * 0.7;
    const guideH = 16;
    const waveAmp = guideH * 0.45;
    const k0 = 14;

    // Boundary condition regions
    ctx.fillStyle = bcFill;
    ctx.fillRect(zLeft - 5, wgTop, 20, wgH);
    ctx.fillRect(zRight - 15, wgTop, 20, wgH);

    // BC lines
    ctx.strokeStyle = colorBC;
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.moveTo(zLeft, wgTop);
    ctx.lineTo(zLeft, wgTop + wgH);
    ctx.stroke();
    ctx.beginPath();
    ctx.moveTo(zRight, wgTop);
    ctx.lineTo(zRight, wgTop + wgH);
    ctx.stroke();

    // BC labels
    ctx.fillStyle = colorBC;
    ctx.font = '10px system-ui';
    ctx.textAlign = 'center';
    ctx.fillText('Initial', zLeft, wgTop - 8);
    ctx.fillText('measurement', zLeft, wgTop - 0);
    ctx.fillText(`r₀ = ${r0.toFixed(2)}`, zLeft, wgTop + wgH + 14);
    ctx.fillText('Final', zRight, wgTop - 8);
    ctx.fillText('measurement', zRight, wgTop - 0);
    ctx.fillText(`rL = ${rL.toFixed(2)}`, zRight, wgTop + wgH + 14);
    ctx.textAlign = 'left';

    // z axis label
    ctx.fillStyle = mutedColor;
    ctx.font = '12px system-ui';
    ctx.textAlign = 'center';
    ctx.fillText('z (time) →', (zLeft + zRight) / 2, wgTop + wgH + 30);
    ctx.textAlign = 'left';

    // Forward mode ψ — propagating right
    ctx.strokeStyle = axisColor;
    ctx.lineWidth = 0.5;
    ctx.beginPath();
    ctx.moveTo(zLeft, fwdY);
    ctx.lineTo(zRight, fwdY);
    ctx.stroke();

    // Backward mode ψ* — propagating left
    ctx.beginPath();
    ctx.moveTo(zLeft, bwdY);
    ctx.lineTo(zRight, bwdY);
    ctx.stroke();

    // Draw forward wave ψ
    ctx.beginPath();
    ctx.strokeStyle = colorFwd;
    ctx.lineWidth = 2;
    for (let i = 0; i <= nPts; i++) {
      const frac = i / nPts;
      const x = zLeft + frac * plotW;
      const z = frac * L;
      const envelope = psiF[i];
      const wave = envelope * Math.sin(k0 * z - time * 3) * waveAmp;
      i === 0 ? ctx.moveTo(x, fwdY + wave) : ctx.lineTo(x, fwdY + wave);
    }
    ctx.stroke();

    // Draw backward wave ψ*
    ctx.beginPath();
    ctx.strokeStyle = colorBwd;
    ctx.lineWidth = 2;
    for (let i = 0; i <= nPts; i++) {
      const frac = i / nPts;
      const x = zLeft + frac * plotW;
      const z = frac * L;
      const envelope = psiB[i];
      const wave = envelope * Math.sin(-k0 * z - time * 3) * waveAmp;
      i === 0 ? ctx.moveTo(x, bwdY + wave) : ctx.lineTo(x, bwdY + wave);
    }
    ctx.stroke();

    // Mode labels with direction arrows
    ctx.fillStyle = colorFwd;
    ctx.font = '11px system-ui';
    ctx.fillText('ψ (forward time) →', zLeft + 10, fwdY - guideH - 2);
    ctx.fillStyle = colorBwd;
    ctx.fillText('← ψ* (reverse time)', zLeft + 10, bwdY - guideH - 2);

    // Coupling arrows between modes
    ctx.globalAlpha = 0.25;
    for (let i = 0; i < 8; i++) {
      const frac = (i + 0.5) / 8;
      const x = zLeft + frac * plotW;
      drawArrow(x, fwdY + guideH, x, bwdY - guideH, colorLoop, 1, 5);
      drawArrow(x + 8, bwdY - guideH, x + 8, fwdY + guideH, colorLoop, 1, 5);
    }
    ctx.globalAlpha = 1;

    // κ label
    ctx.fillStyle = colorLoop;
    ctx.font = '10px system-ui';
    ctx.textAlign = 'center';
    ctx.fillText('κ', (zLeft + zRight) / 2, (fwdY + bwdY) / 2 + 3);
    ctx.textAlign = 'left';

    // Loop arrows at boundaries showing the reflection/consistency
    // At z=0: ψ*(0) reflects into ψ(0)
    const loopR = 18;
    ctx.strokeStyle = colorBC;
    ctx.lineWidth = 2;
    // Left boundary: curved arrow from ψ* up to ψ
    ctx.beginPath();
    ctx.arc(zLeft - 8, (fwdY + bwdY) / 2, (bwdY - fwdY) / 2 - 4, Math.PI * 0.6, -Math.PI * 0.6, true);
    ctx.stroke();
    // Arrowhead at top
    drawArrow(zLeft - 6, fwdY + 8, zLeft, fwdY + 4, colorBC, 2, 6);

    // Right boundary: curved arrow from ψ down to ψ*
    ctx.beginPath();
    ctx.arc(zRight + 8, (fwdY + bwdY) / 2, (bwdY - fwdY) / 2 - 4, -Math.PI * 0.6, Math.PI * 0.6, false);
    ctx.stroke();
    drawArrow(zRight + 6, bwdY - 8, zRight, bwdY - 4, colorBC, 2, 6);

    // === Bottom: Amplitude envelopes ===
    const ampBot = ampTop + ampH;

    // Axes
    ctx.strokeStyle = axisColor;
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(zLeft, ampTop);
    ctx.lineTo(zLeft, ampBot);
    ctx.lineTo(zRight, ampBot);
    ctx.stroke();

    ctx.fillStyle = mutedColor;
    ctx.font = '10px system-ui';
    ctx.fillText('|amplitude|', margin.left - 60, ampTop + ampH / 2);
    ctx.textAlign = 'center';
    ctx.fillText('z (time) →', (zLeft + zRight) / 2, ampBot + 16);
    ctx.textAlign = 'left';

    // |ψ(z)|
    ctx.beginPath();
    ctx.strokeStyle = colorFwd;
    ctx.lineWidth = 2.5;
    for (let i = 0; i <= nPts; i++) {
      const x = zLeft + (i / nPts) * plotW;
      const y = ampBot - Math.abs(psiF[i]) * ampH * 0.9;
      i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    }
    ctx.stroke();

    // |ψ*(z)|
    ctx.beginPath();
    ctx.strokeStyle = colorBwd;
    ctx.lineWidth = 2.5;
    for (let i = 0; i <= nPts; i++) {
      const x = zLeft + (i / nPts) * plotW;
      const y = ampBot - Math.abs(psiB[i]) * ampH * 0.9;
      i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    }
    ctx.stroke();

    // Legend
    ctx.fillStyle = colorFwd;
    ctx.fillRect(zLeft + 10, ampTop + 6, 12, 3);
    ctx.fillStyle = textColor;
    ctx.font = '10px system-ui';
    ctx.fillText('|ψ(z)|', zLeft + 26, ampTop + 12);

    ctx.fillStyle = colorBwd;
    ctx.fillRect(zLeft + 80, ampTop + 6, 12, 3);
    ctx.fillStyle = textColor;
    ctx.fillText('|ψ*(z)|', zLeft + 96, ampTop + 12);

    // Self-consistency indicator
    const isConsistent = Math.abs(consistent - 1) < 0.05;
    ctx.fillStyle = isConsistent ? colorLoop : (isDark ? '#ff4444' : '#dc2626');
    ctx.font = 'bold 12px system-ui';
    ctx.textAlign = 'right';
    if (isConsistent) {
      ctx.fillText('✓ Self-consistent loop', zRight, ampTop + 14);
    } else {
      ctx.fillText(`Round-trip ratio: ${consistent.toFixed(3)}`, zRight, ampTop + 14);
      ctx.font = '10px system-ui';
      ctx.fillStyle = mutedColor;
      ctx.fillText('(= 1 for self-consistency)', zRight, ampTop + 28);
    }
    ctx.textAlign = 'left';

    time += 0.016;
    if (isVisible) requestAnimationFrame(draw);
  }

  let isVisible = false;
  const observer = new IntersectionObserver(([entry]) => {
    const wasVisible = isVisible;
    isVisible = entry.isIntersecting;
    if (isVisible && !wasVisible) requestAnimationFrame(draw);
  }, { threshold: 0.1 });
  observer.observe(canvas.closest('.diagram-container')!);
</script>
