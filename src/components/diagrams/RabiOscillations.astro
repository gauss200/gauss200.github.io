---
// Rabi oscillations showing occupation probability oscillating between two quantum states
// Identical math to coupled mode energy exchange
---
<div class="diagram-container">
  <h3>Rabi Oscillations — Quantum State Transfer</h3>
  <p class="diagram-desc">
    Occupation probability oscillates between states |1⟩ and |2⟩ at the Rabi frequency.
    This is mathematically identical to energy exchange in coupled waveguides.
  </p>
  <div class="diagram-controls">
    <label>
      Rabi frequency (&Omega;):
      <input type="range" id="rabi-omega" min="0.5" max="5" step="0.1" value="2" />
    </label>
  </div>
  <canvas id="rabi-canvas" width="800" height="250"></canvas>
</div>

<style>
  .diagram-container {
    margin: 2rem 0;
    padding: 1.5rem;
    background: var(--color-card-bg);
    border-radius: var(--border-radius);
    box-shadow: 0 2px 8px var(--color-card-shadow);
  }
  .diagram-desc { color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 1rem; }
  .diagram-controls { display: flex; gap: 2rem; margin-bottom: 1rem; }
  .diagram-controls label { font-size: 0.85rem; display: flex; align-items: center; gap: 0.5rem; }
  canvas { width: 100%; height: auto; display: block; border-radius: var(--border-radius); }
</style>

<script>
  const canvas = document.getElementById('rabi-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const omegaSlider = document.getElementById('rabi-omega') as HTMLInputElement;

  let time = 0;

  function draw() {
    const W = canvas.width;
    const H = canvas.height;
    const omega = parseFloat(omegaSlider.value);
    const isDark = document.documentElement.getAttribute('data-theme') === 'ds9';

    ctx.clearRect(0, 0, W, H);
    ctx.fillStyle = isDark ? '#0a0a12' : '#fafaf8';
    ctx.fillRect(0, 0, W, H);

    const margin = { left: 60, right: 20, top: 20, bottom: 40 };
    const plotW = W - margin.left - margin.right;
    const plotH = H - margin.top - margin.bottom;

    // Axes
    ctx.strokeStyle = isDark ? '#2a2d4a' : '#d4d0ca';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(margin.left, margin.top);
    ctx.lineTo(margin.left, margin.top + plotH);
    ctx.lineTo(margin.left + plotW, margin.top + plotH);
    ctx.stroke();

    // Labels
    ctx.fillStyle = isDark ? '#c8cad8' : '#1a1a1a';
    ctx.font = '12px system-ui';
    ctx.fillText('P(t)', 10, margin.top + plotH / 2);
    ctx.fillText('Time →', margin.left + plotW / 2, H - 5);
    ctx.fillText('1.0', margin.left - 30, margin.top + 5);
    ctx.fillText('0.0', margin.left - 30, margin.top + plotH + 5);

    // P1(t) = cos²(Ωt/2), P2(t) = sin²(Ωt/2)
    const color1 = isDark ? '#e8a640' : '#2563eb';
    const color2 = isDark ? '#64b5f6' : '#dc2626';

    for (let i = 0; i < 2; i++) {
      ctx.beginPath();
      ctx.strokeStyle = i === 0 ? color1 : color2;
      ctx.lineWidth = 2;

      for (let px = 0; px <= plotW; px++) {
        const t = (px / plotW) * 10 + time;
        const p = i === 0
          ? Math.cos(omega * t / 2) ** 2
          : Math.sin(omega * t / 2) ** 2;
        const x = margin.left + px;
        const y = margin.top + plotH * (1 - p);
        px === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      }
      ctx.stroke();
    }

    // Legend
    ctx.fillStyle = color1;
    ctx.fillRect(margin.left + plotW - 150, margin.top + 10, 12, 12);
    ctx.fillStyle = isDark ? '#c8cad8' : '#1a1a1a';
    ctx.fillText('P₁(t) = cos²(Ωt/2)', margin.left + plotW - 132, margin.top + 20);

    ctx.fillStyle = color2;
    ctx.fillRect(margin.left + plotW - 150, margin.top + 28, 12, 12);
    ctx.fillStyle = isDark ? '#c8cad8' : '#1a1a1a';
    ctx.fillText('P₂(t) = sin²(Ωt/2)', margin.left + plotW - 132, margin.top + 38);

    time += 0.02;
    requestAnimationFrame(draw);
  }

  draw();
</script>
