---
interface Props {
  title: string;
  status: string;
  year_start: number;
  year_end?: number;
  summary: string;
}

const { title, status, year_start, year_end, summary } = Astro.props;
const years = year_end ? `${year_start}–${year_end}` : `${year_start}–present`;
---
<article class="card project-card">
  <div class="project-card__header">
    <h3>{title}</h3>
    <span class="project-card__years">{years}</span>
    <span class:list={['project-card__badge', status]}>{status}</span>
  </div>
  <p class="project-card__summary">{summary}</p>
  <div class="project-card__body"><slot /></div>
</article>

<style>
  .project-card { margin-bottom: 1.5rem; }
  .project-card__header { display: flex; align-items: baseline; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 0.5rem; }
  .project-card__years { font-size: 0.85rem; color: var(--color-text-muted); }
  .project-card__badge { font-size: 0.75rem; padding: 0.1rem 0.5rem; border-radius: 12px; text-transform: uppercase; }
  .project-card__badge.active { background: var(--color-accent); color: white; }
  .project-card__badge.completed { background: var(--color-bg-secondary); color: var(--color-text-muted); }
  .project-card__summary { color: var(--color-text-muted); font-size: 0.95rem; }
  .project-card__body { margin-top: 0.75rem; font-size: 0.9rem; }
</style>
