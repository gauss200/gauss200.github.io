---
interface Props {
  title: string;
  status: string;
  year_start: number;
  year_end?: number;
  summary: string;
  image?: string;
  slug: string;
}

const { title, status, year_start, year_end, summary, image, slug } = Astro.props;
const years = year_end ? `${year_start}–${year_end}` : `${year_start}–present`;
---
<a href={`/projects/${slug}`} class="project-card__link">
  <article class="card project-card">
    {image && (
      <div class="project-card__image">
        <img src={image} alt={title} loading="lazy" />
      </div>
    )}
    <div class="project-card__content">
      <div class="project-card__header">
        <h3>{title}</h3>
        <span class="project-card__years">{years}</span>
        <span class:list={['project-card__badge', status]}>{status}</span>
      </div>
      <p class="project-card__summary">{summary}</p>
    </div>
  </article>
</a>

<style>
  .project-card__link {
    text-decoration: none;
    color: inherit;
    display: block;
    margin-bottom: 1.5rem;
  }
  .project-card__link:hover .project-card {
    background: var(--color-bg-secondary);
  }
  .project-card {
    display: flex;
    gap: 1.25rem;
  }
  .project-card__image {
    flex-shrink: 0;
    width: 160px;
    height: 110px;
    overflow: hidden;
    border: 2px solid var(--color-border);
  }
  .project-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .project-card__content { flex: 1; min-width: 0; }
  .project-card__header { display: flex; align-items: baseline; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 0.25rem; }
  .project-card__header h3 { text-decoration: underline; text-underline-offset: 2px; }
  .project-card__years { font-size: 0.85rem; color: var(--color-text-muted); font-family: var(--font-mono); }
  .project-card__badge { font-size: 0.7rem; padding: 0.1rem 0.4rem; border: 1px solid var(--color-border); text-transform: uppercase; font-family: var(--font-mono); letter-spacing: 0.05em; }
  .project-card__badge.active { background: var(--color-accent); color: var(--color-bg); border-color: var(--color-accent); }
  .project-card__badge.completed { background: transparent; color: var(--color-text-muted); }
  .project-card__summary { color: var(--color-text-muted); font-size: 0.9rem; margin-top: 0.25rem; }

  @media (max-width: 580px) {
    .project-card { flex-direction: column; }
    .project-card__image { width: 100%; height: 140px; }
  }
</style>
