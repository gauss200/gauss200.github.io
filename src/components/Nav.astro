---
import ThemeToggle from './ThemeToggle.astro';

const links = [
  { href: '/', label: 'Home' },
  { href: '/research', label: 'Research' },
  { href: '/publications', label: 'Publications' },
  { href: '/hobbies', label: 'Hobbies' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---
<nav class="nav">
  <div class="nav__inner container">
    <a href="/" class="nav__logo">W.B. Jackson</a>
    <ul class="nav__links">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class:list={['nav__link', { active: currentPath === link.href }]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <ThemeToggle />
  </div>
</nav>

<style>
  .nav {
    background: var(--color-nav-bg);
    padding: 0.75rem 0;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .nav__logo {
    color: var(--color-nav-text);
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    text-decoration: none;
  }

  .nav__links {
    display: flex;
    list-style: none;
    gap: 1.25rem;
  }

  .nav__link {
    color: var(--color-nav-text);
    opacity: 0.8;
    font-size: 0.9rem;
    transition: opacity var(--transition-speed);
  }

  .nav__link:hover, .nav__link.active {
    opacity: 1;
  }
</style>
