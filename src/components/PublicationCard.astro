---
interface Props {
  title: string;
  authors: string;
  journal: string;
  year: number;
  doi?: string;
  image?: string;
}

const { title, authors, journal, year, doi, image } = Astro.props;
---
<article class="card pub-card">
  {image && (
    <div class="pub-card__image">
      <img src={image} alt={title} loading="lazy" />
    </div>
  )}
  <div class="pub-card__content">
    <h3 class="pub-card__title">{title}</h3>
    <p class="pub-card__authors">{authors}</p>
    <p class="pub-card__meta">
      <em>{journal}</em>, {year}
      {doi && doi !== '' && <a href={`https://doi.org/${doi}`} target="_blank" rel="noopener">DOI</a>}
    </p>
    <div class="pub-card__body">
      <slot />
    </div>
  </div>
</article>

<style>
  .pub-card {
    margin-bottom: 1.5rem;
    display: flex;
    gap: 1.25rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
    border: none;
    box-shadow: none;
    padding: 0 0 1.5rem 0;
  }
  .pub-card__image {
    flex-shrink: 0;
    width: 140px;
    height: 90px;
    overflow: hidden;
    border: 1px solid var(--color-border);
  }
  .pub-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .pub-card__content { flex: 1; min-width: 0; }
  .pub-card__title { font-size: 1rem; margin-bottom: 0.15rem; font-weight: 700; }
  .pub-card__authors { font-size: 0.85rem; color: var(--color-text-muted); font-style: italic; }
  .pub-card__meta { font-size: 0.8rem; color: var(--color-text-muted); margin-bottom: 0.4rem; font-family: var(--font-mono); }
  .pub-card__meta a { margin-left: 0.5rem; }
  .pub-card__body { font-size: 0.9rem; }

  @media (max-width: 580px) {
    .pub-card { flex-direction: column; }
    .pub-card__image { width: 100%; height: 120px; }
  }
</style>
