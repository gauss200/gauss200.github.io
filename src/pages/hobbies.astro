---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const hobbies = (await getCollection('hobbies')).sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title="Hobbies">
  <section class="page-header">
    <h1>Hobbies</h1>
  </section>

  <section class="hobbies-grid">
    {hobbies.map(async (hobby) => {
      const { Content } = await render(hobby);
      return (
        <article class="card">
          <h3>{hobby.data.title}</h3>
          <p>{hobby.data.summary}</p>
          <Content />
        </article>
      );
    })}
  </section>
</BaseLayout>

<style>
  .page-header { padding: 3rem 0 2rem; }
  .hobbies-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; }
</style>
