---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, getEntry, render } from 'astro:content';

// Import all diagram components
import CoupledWaveguides from '../../components/diagrams/CoupledWaveguides.astro';
import CoPropagatingModes from '../../components/diagrams/CoPropagatingModes.astro';
import CounterPropagating from '../../components/diagrams/CounterPropagating.astro';
import QuantumTunneling from '../../components/diagrams/QuantumTunneling.astro';
import QuantumMeasurement from '../../components/diagrams/QuantumMeasurement.astro';
import PeriodicCoupledModes from '../../components/diagrams/PeriodicCoupledModes.astro';
import ContinuumDecay from '../../components/diagrams/ContinuumDecay.astro';
import EPRExperiment from '../../components/diagrams/EPRExperiment.astro';
import TwoModeCoupler from '../../components/diagrams/TwoModeCoupler.astro';
import FundamentalTheorem from '../../components/diagrams/FundamentalTheorem.astro';
import ActionQuantization from '../../components/diagrams/ActionQuantization.astro';

// Map diagram names to components
const diagramMap: Record<string, any> = {
  CoupledWaveguides,
  CoPropagatingModes,
  CounterPropagating,
  QuantumTunneling,
  QuantumMeasurement,
  PeriodicCoupledModes,
  ContinuumDecay,
  EPRExperiment,
  TwoModeCoupler,
  FundamentalTheorem,
  ActionQuantization,
};

// Get page intro from the projects collection
const project = await getEntry('projects', 'quantum-foundations');
const { Content: PageIntro } = await render(project!);

// Get diagram sections sorted by order
const sections = (await getCollection('diagram_sections')).sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title="Foundations of Quantum Mechanics">
  <section class="page-header">
    <h1>{project!.data.title}</h1>
    <div class="page-intro">
      <PageIntro />
    </div>
  </section>

  <section class="diagram-grid">
    {sections.map(async (section) => {
      const { Content } = await render(section);
      const DiagramComponent = diagramMap[section.data.diagram];
      return (
        <div>
          <div class="diagram-intro">
            <h2>{section.data.title}</h2>
            <div class="diagram-desc-body"><Content /></div>
          </div>
          {DiagramComponent && <DiagramComponent />}
        </div>
      );
    })}
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 3rem 0 1rem;
  }

  .page-header h1 {
    margin-bottom: 1rem;
  }

  .page-intro {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 720px;
  }

  .page-intro :global(p) {
    margin-bottom: 0.75rem;
  }

  .diagram-grid {
    padding: 1rem 0 2rem;
  }

  .diagram-intro {
    margin-top: 3rem;
    margin-bottom: 0.5rem;
  }

  .diagram-intro h2 {
    margin-bottom: 0.5rem;
  }

  .diagram-desc-body {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    max-width: 680px;
  }

  .diagram-desc-body :global(p) {
    margin-bottom: 0.5rem;
  }
</style>
