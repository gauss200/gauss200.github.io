---
import BaseLayout from '../layouts/BaseLayout.astro';
import PublicationCard from '../components/PublicationCard.astro';
import PatentCard from '../components/PatentCard.astro';
import { getCollection, render } from 'astro:content';

const publications = (await getCollection('publications')).sort((a, b) => b.data.year - a.data.year);
const patents = (await getCollection('patents')).sort((a, b) => b.data.year - a.data.year);
---
<BaseLayout title="Publications & Patents">
  <section class="page-header">
    <h1>Publications & Patents</h1>
    <p>Over 250 refereed publications and 100+ granted patents.</p>
  </section>

  <section>
    <h2>Selected Publications</h2>
    {publications.map(async (pub) => {
      const { Content } = await render(pub);
      return (
        <PublicationCard {...pub.data}>
          <Content />
        </PublicationCard>
      );
    })}
  </section>

  <section class="patents-section">
    <h2>Selected Patents</h2>
    {patents.map(async (patent) => {
      const { Content } = await render(patent);
      return (
        <PatentCard {...patent.data}>
          <Content />
        </PatentCard>
      );
    })}
  </section>
</BaseLayout>

<style>
  .page-header { padding: 3rem 0 2rem; }
  .page-header h1 { margin-bottom: 0.5rem; }
  .page-header p { color: var(--color-text-muted); }
  section h2 { margin-bottom: 1.5rem; margin-top: 2rem; }
  .patents-section { margin-top: 3rem; }
</style>
