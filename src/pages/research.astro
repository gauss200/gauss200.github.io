---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import CoupledWaveguides from '../components/diagrams/CoupledWaveguides.astro';
import BlochSphere from '../components/diagrams/BlochSphere.astro';
import RabiOscillations from '../components/diagrams/RabiOscillations.astro';
import QuantumTunneling from '../components/diagrams/QuantumTunneling.astro';
import CounterPropagating from '../components/diagrams/CounterPropagating.astro';
import { getCollection, render } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title="Research & Projects">
  <section class="page-header">
    <h1>Research & Projects</h1>
    <p>Four decades of research spanning fundamental semiconductor physics, device engineering, and machine learning.</p>
  </section>

  <section>
    {projects.map(async (project) => {
      const { Content } = await render(project);
      return (
        <ProjectCard {...project.data}>
          <Content />
        </ProjectCard>
      );
    })}
  </section>

  <section class="diagrams-section">
    <h2>Interactive Physics: Coupled Mode Theory & Quantum Mechanics</h2>
    <p class="section-intro">
      Coupled mode theory (CMT) and quantum two-level systems share identical mathematical
      structure. Explore the connections through these interactive visualizations.
    </p>

    <CoupledWaveguides />
    <CounterPropagating />
    <RabiOscillations />
    <QuantumTunneling />
    <BlochSphere />
  </section>
</BaseLayout>

<style>
  .page-header { padding: 3rem 0 2rem; }
  .page-header h1 { margin-bottom: 0.5rem; }
  .page-header p { color: var(--color-text-muted); }
  .diagrams-section { margin-top: 4rem; }
  .diagrams-section h2 { margin-bottom: 0.5rem; }
  .section-intro { color: var(--color-text-muted); margin-bottom: 2rem; }
</style>
