---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const essays = (await getCollection('essays'))
  .filter(e => !e.id.startsWith('test'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---
<BaseLayout title="Home">
  <section class="page-header">
    <h1>Essays</h1>
    <p class="page-intro">Writing on physics, mathematics, and their connections to other fields.</p>
  </section>

  <ul class="essay-list">
    {essays.map(essay => (
      <li class="essay-card">
        <a href={`/essays/${essay.id}`} class="essay-card__inner">
          {essay.data.figure && (
            <div class="essay-card__figure">
              <img src={essay.data.figure} alt="" aria-hidden="true" />
            </div>
          )}
          <div class="essay-card__body">
            <h2 class="essay-card__title">{essay.data.title}</h2>
            <p class="essay-card__summary">{essay.data.summary}</p>
            <span class="essay-card__read">Read condensed version →</span>
          </div>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .page-header {
    padding: 3rem 0 2rem;
  }

  .page-intro {
    color: var(--color-text-muted);
    font-size: 1rem;
    margin-top: 0.5rem;
  }

  .essay-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .essay-card {
    border-top: 1px solid var(--color-border);
  }

  .essay-list li:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .essay-card__inner {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
    padding: 1.75rem 0;
    text-decoration: none;
    color: inherit;
  }

  .essay-card__inner:hover .essay-card__title {
    color: var(--color-accent);
  }

  .essay-card__figure {
    flex-shrink: 0;
    width: 140px;
    height: 100px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-bg-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .essay-card__figure img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .essay-card__body {
    flex: 1;
    min-width: 0;
  }

  .essay-card__title {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.4rem;
    line-height: 1.3;
    transition: color 0.15s;
  }

  .essay-card__summary {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .essay-card__read {
    font-size: 0.8rem;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  @media (max-width: 540px) {
    .essay-card__inner {
      flex-direction: column;
      gap: 1rem;
    }
    .essay-card__figure {
      width: 100%;
      height: 140px;
    }
  }
</style>
